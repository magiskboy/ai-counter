# Copy to .env and adjust (gitignored).
#   cp .env.example .env

# Sandbox directory on host (mounted as /home/counter in container)
SANDBOX=~/ai-counter-sandbox

# Container name and image tag
# NAME=ai-counter
# IMAGE=ai-counter:latest

# Optional: Context7 MCP (see sandbox/.cursor/mcp.json)
# CONTEXT7_API_KEY=
